<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SPACE CONTROL — Mission Command</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600&display=swap');

  :root {
    --void: #020510;
    --deep: #060d1f;
    --panel: #0a1628;
    --grid: #0e1e38;
    --cyan: #00f5ff;
    --pulse: #00bfff;
    --amber: #ffaa00;
    --crimson: #ff3860;
    --green: #00ff88;
    --dim: rgba(0,245,255,0.08);
    --glow: 0 0 20px rgba(0,245,255,0.5);
    --glow-strong: 0 0 40px rgba(0,245,255,0.8);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--void);
    color: #c8e0ff;
    font-family: 'Exo 2', sans-serif;
    overflow-x: hidden;
  }

  /* ── STARFIELD ── */
  #starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 3rem;
    background: linear-gradient(180deg, rgba(2,5,16,0.95) 0%, transparent 100%);
    border-bottom: 1px solid rgba(0,245,255,0.1);
    backdrop-filter: blur(6px);
  }

  .nav-logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--cyan);
    letter-spacing: 0.25em;
    text-shadow: var(--glow);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: rgba(200,224,255,0.6);
    text-decoration: none;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.3s, text-shadow 0.3s;
  }

  .nav-links a:hover {
    color: var(--cyan);
    text-shadow: var(--glow);
  }

  .nav-status {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--green);
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: blink 1.4s infinite;
  }

  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

  /* ── HERO ── */
  #hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,245,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,245,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    animation: gridPulse 6s ease-in-out infinite;
  }

  @keyframes gridPulse { 0%,100%{opacity:0.5} 50%{opacity:1} }

  .hero-orbit {
    position: absolute;
    border: 1px solid rgba(0,245,255,0.08);
    border-radius: 50%;
    animation: spin linear infinite;
  }
  .orbit1 { width:500px; height:500px; top:50%; left:50%; transform:translate(-50%,-50%); animation-duration: 30s; }
  .orbit2 { width:750px; height:750px; top:50%; left:50%; transform:translate(-50%,-50%); animation-duration: 50s; animation-direction: reverse; }
  .orbit3 { width:1100px; height:1100px; top:50%; left:50%; transform:translate(-50%,-50%); animation-duration: 80s; }

  @keyframes spin { from{transform:translate(-50%,-50%) rotate(0deg)} to{transform:translate(-50%,-50%) rotate(360deg)} }

  .orbit-dot {
    position: absolute;
    width: 8px; height: 8px;
    background: var(--cyan);
    border-radius: 50%;
    top: -4px; left: 50%;
    margin-left: -4px;
    box-shadow: 0 0 10px var(--cyan);
  }

  .orbit2 .orbit-dot { background: var(--amber); box-shadow: 0 0 10px var(--amber); }
  .orbit3 .orbit-dot { background: var(--crimson); box-shadow: 0 0 10px var(--crimson); }

  .eyebrow {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.4em;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 1s 0.3s forwards;
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(2.8rem, 8vw, 7rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.01em;
    color: #fff;
    text-shadow: 0 0 80px rgba(0,245,255,0.3);
    opacity: 0;
    animation: fadeUp 1s 0.6s forwards;
  }

  .hero-title span {
    color: var(--cyan);
    text-shadow: var(--glow-strong);
  }

  .hero-sub {
    margin-top: 1.5rem;
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 300;
    color: rgba(200,224,255,0.65);
    max-width: 550px;
    line-height: 1.7;
    opacity: 0;
    animation: fadeUp 1s 0.9s forwards;
  }

  .hero-cta {
    margin-top: 3rem;
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fadeUp 1s 1.2s forwards;
  }

  .btn-primary {
    padding: 0.85rem 2.4rem;
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: color 0.3s, box-shadow 0.3s;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--cyan);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
    z-index: -1;
  }

  .btn-primary:hover { color: var(--void); box-shadow: var(--glow); }
  .btn-primary:hover::before { transform: scaleX(1); }

  .btn-ghost {
    padding: 0.85rem 2.4rem;
    background: transparent;
    border: 1px solid rgba(200,224,255,0.2);
    color: rgba(200,224,255,0.6);
    font-family: 'Orbitron', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.3s, color 0.3s;
  }

  .btn-ghost:hover { border-color: rgba(200,224,255,0.5); color: #fff; }

  @keyframes fadeUp {
    from { opacity:0; transform: translateY(30px); }
    to   { opacity:1; transform: translateY(0); }
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0.4;
    animation: float 2s ease-in-out infinite;
  }

  .scroll-indicator span {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--cyan);
  }

  .scroll-arrow {
    width: 1px; height: 40px;
    background: linear-gradient(180deg, var(--cyan), transparent);
  }

  @keyframes float { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(8px)} }

  /* ── SECTION BASE ── */
  section {
    position: relative;
    z-index: 1;
    padding: 6rem 3rem;
    max-width: 1300px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    color: var(--cyan);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    opacity: 0.7;
  }

  .section-title {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .section-title span { color: var(--cyan); }

  .section-divider {
    width: 60px; height: 2px;
    background: linear-gradient(90deg, var(--cyan), transparent);
    margin-bottom: 3rem;
  }

  /* ── MISSION STATS ── */
  #stats {
    padding: 4rem 3rem;
    background: linear-gradient(180deg, transparent, rgba(0,245,255,0.03) 50%, transparent);
    border-top: 1px solid rgba(0,245,255,0.07);
    border-bottom: 1px solid rgba(0,245,255,0.07);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    max-width: 1300px;
    margin: 0 auto;
    background: rgba(0,245,255,0.05);
  }

  .stat-cell {
    background: var(--deep);
    padding: 2.5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }

  .stat-cell:hover { background: var(--grid); }

  .stat-cell::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--cyan), transparent);
    transform: scaleX(0);
    transition: transform 0.4s;
  }

  .stat-cell:hover::before { transform: scaleX(1); }

  .stat-number {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--cyan);
    text-shadow: var(--glow);
    display: block;
    counter-reset: none;
  }

  .stat-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    color: rgba(200,224,255,0.45);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin-top: 0.4rem;
    display: block;
  }

  /* ── MISSIONS ── */
  .missions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5px;
    background: rgba(0,245,255,0.05);
  }

  .mission-card {
    background: var(--deep);
    padding: 2.5rem 2rem;
    position: relative;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    overflow: hidden;
  }

  .mission-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--cyan);
    transform: scaleY(0);
    transition: transform 0.3s;
    transform-origin: bottom;
  }

  .mission-card:hover { background: var(--grid); }
  .mission-card:hover::after { transform: scaleY(1); }
  .mission-card.amber::after { background: var(--amber); }
  .mission-card.crimson::after { background: var(--crimson); }
  .mission-card.green::after { background: var(--green); }

  .mission-icon {
    font-size: 2.5rem;
    margin-bottom: 1.2rem;
    display: block;
  }

  .mission-title {
    font-family: 'Orbitron', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .mission-desc {
    font-size: 0.88rem;
    color: rgba(200,224,255,0.55);
    line-height: 1.7;
  }

  .mission-tag {
    display: inline-block;
    margin-top: 1.2rem;
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(0,245,255,0.3);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--cyan);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .mission-card.amber .mission-tag { border-color: rgba(255,170,0,0.3); color: var(--amber); }
  .mission-card.crimson .mission-tag { border-color: rgba(255,56,96,0.3); color: var(--crimson); }
  .mission-card.green .mission-tag { border-color: rgba(0,255,136,0.3); color: var(--green); }

  /* ── KALPANA CHAWLA ── */
  #kalpana {
    position: relative;
    z-index: 1;
    padding: 8rem 3rem;
    overflow: hidden;
    background: none;
    max-width: none;
  }

  .kalpana-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 50%, rgba(100,0,200,0.12) 0%, transparent 70%),
      linear-gradient(180deg, transparent 0%, rgba(6,4,20,0.95) 100%);
    z-index: 0;
  }

  .kalpana-stars {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .kalpana-inner {
    position: relative;
    z-index: 1;
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: center;
  }

  .kalpana-portrait {
    position: relative;
  }

  .portrait-frame {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 3/4;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .portrait-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(180,120,255,0.4);
    z-index: 2;
  }

  .portrait-frame::after {
    content: '';
    position: absolute;
    top: 12px; left: 12px; right: -12px; bottom: -12px;
    border: 1px solid rgba(180,120,255,0.15);
    z-index: 0;
  }

  .portrait-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .portrait-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    filter: saturate(0.85) contrast(1.05);
  }

  .portrait-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 3px,
      rgba(0,0,0,0.08) 3px,
      rgba(0,0,0,0.08) 4px
    );
    z-index: 3;
    pointer-events: none;
  }

  .kalpana-badge {
    position: absolute;
    bottom: -1.5rem;
    right: -1rem;
    background: var(--deep);
    border: 1px solid rgba(180,120,255,0.4);
    padding: 1rem 1.5rem;
    z-index: 10;
  }

  .badge-mission {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: rgba(200,224,255,0.5);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .badge-number {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: #b478ff;
    text-shadow: 0 0 20px rgba(180,120,255,0.6);
    display: block;
    margin-top: 0.25rem;
  }

  .kalpana-content .section-label { color: #b478ff; }
  .kalpana-content .section-title span { color: #b478ff; text-shadow: 0 0 20px rgba(180,120,255,0.5); }
  .kalpana-content .section-divider { background: linear-gradient(90deg, #b478ff, transparent); }

  .kalpana-quote {
    font-family: 'Exo 2', sans-serif;
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 300;
    font-style: italic;
    color: rgba(200,224,255,0.85);
    line-height: 1.8;
    border-left: 3px solid #b478ff;
    padding-left: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .kalpana-body {
    font-size: 0.95rem;
    color: rgba(200,224,255,0.6);
    line-height: 1.85;
    margin-bottom: 2rem;
  }

  .kalpana-timeline {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin-top: 2.5rem;
    background: rgba(180,120,255,0.1);
  }

  .timeline-row {
    display: grid;
    grid-template-columns: 90px 1fr;
    background: var(--deep);
    transition: background 0.2s;
  }

  .timeline-row:hover { background: var(--grid); }

  .t-year {
    padding: 1rem 1rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #b478ff;
    border-right: 1px solid rgba(180,120,255,0.15);
    display: flex;
    align-items: center;
  }

  .t-event {
    padding: 1rem 1.25rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    color: rgba(200,224,255,0.65);
    display: flex;
    align-items: center;
    letter-spacing: 0.04em;
  }

  .tribute-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding: 0.5rem 1.2rem;
    background: rgba(180,120,255,0.08);
    border: 1px solid rgba(180,120,255,0.3);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    color: #b478ff;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  /* ── CONTROL ROOM ── */
  .control-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5px;
    background: rgba(0,245,255,0.05);
  }

  .control-panel {
    background: var(--deep);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }

  .control-panel.wide { grid-column: span 2; }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0,245,255,0.08);
  }

  .panel-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: var(--cyan);
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .panel-live {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--green);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .telemetry-bars {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tel-row {
    display: grid;
    grid-template-columns: 120px 1fr 50px;
    align-items: center;
    gap: 1rem;
  }

  .tel-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: rgba(200,224,255,0.5);
    letter-spacing: 0.1em;
  }

  .tel-track {
    height: 4px;
    background: rgba(0,245,255,0.08);
    border-radius: 0;
    overflow: hidden;
    position: relative;
  }

  .tel-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--cyan), #0080ff);
    border-radius: 0;
    animation: barLoad 2s ease forwards;
    transform-origin: left;
    transform: scaleX(0);
  }

  .tel-fill.amber { background: linear-gradient(90deg, var(--amber), #ff6600); }
  .tel-fill.green { background: linear-gradient(90deg, var(--green), #00aa55); }
  .tel-fill.crimson { background: linear-gradient(90deg, var(--crimson), #aa0030); }

  @keyframes barLoad { to { transform: scaleX(1); } }

  .tel-value {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--cyan);
    text-align: right;
  }

  .mission-log {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .log-entry {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: 1rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(0,245,255,0.04);
  }

  .log-time { color: rgba(0,245,255,0.4); }
  .log-msg { color: rgba(200,224,255,0.6); }
  .log-msg.warn { color: var(--amber); }
  .log-msg.ok { color: var(--green); }
  .log-msg.alert { color: var(--crimson); }

  /* ── PLANETS ── */
  #solar {
    padding: 6rem 3rem;
    text-align: center;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }

  .solar-system-wrap {
    position: relative;
    width: 100%;
    height: 500px;
    margin-top: 3rem;
    overflow: hidden;
  }

  .solar-canvas { width: 100%; height: 100%; }

  /* ── FOOTER ── */
  footer {
    position: relative;
    z-index: 1;
    padding: 3rem;
    border-top: 1px solid rgba(0,245,255,0.07);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(6,13,31,0.8);
  }

  .footer-logo {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.9rem;
    font-weight: 900;
    color: var(--cyan);
    letter-spacing: 0.2em;
  }

  .footer-copy {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: rgba(200,224,255,0.3);
    letter-spacing: 0.1em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  .footer-links a {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: rgba(200,224,255,0.3);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.3s;
  }

  .footer-links a:hover { color: var(--cyan); }

  /* ── SCROLL REVEAL ── */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
