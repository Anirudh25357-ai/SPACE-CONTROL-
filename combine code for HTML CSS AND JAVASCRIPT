    { name:'Earth',   r:10, dist:170, speed:0.029, color:'#4a90d9', glow:'rgba(74,144,217,0.4)' },
    { name:'Mars',    r:7,  dist:220, speed:0.024, color:'#d95030', glow:'rgba(217,80,48,0.4)'  },
    { name:'Jupiter', r:22, dist:300, speed:0.013, color:'#c89060', glow:'rgba(200,144,96,0.4)' },
    { name:'Saturn',  r:18, dist:390, speed:0.009, color:'#ddb86a', glow:'rgba(221,184,106,0.4)', ring:true },
    { name:'Uranus',  r:12, dist:470, speed:0.006, color:'#70d8e8', glow:'rgba(112,216,232,0.4)' },
    { name:'Neptune', r:11, dist:545, speed:0.005, color:'#3050d0', glow:'rgba(48,80,208,0.4)'  },
  ];

  let angles = planets.map(()=>Math.random()*Math.PI*2);
  let hovered = -1;

  canvas.addEventListener('mousemove', e=>{
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX-rect.left, my = e.clientY-rect.top;
    const cx=canvas.width/2, cy=canvas.height/2;
    hovered=-1;
    planets.forEach((p,i)=>{
      const px=cx+Math.cos(angles[i])*p.dist*scale;
      const py=cy+Math.sin(angles[i])*p.dist*scale;
      if(Math.hypot(mx-px,my-py)<p.r*scale+8) hovered=i;
    });
    canvas.style.cursor = hovered>=0?'pointer':'default';
  });

  let scale=1;

  function draw(){
    canvas.width = canvas.offsetWidth;
    canvas.height = canvas.offsetHeight || 500;
    const w=canvas.width, h=canvas.height;
    const cx=w/2, cy=h/2;
    scale = Math.min(w,h)/700;

    ctx.clearRect(0,0,w,h);

    // Space bg
    ctx.fillStyle='#020510'; ctx.fillRect(0,0,w,h);

    // Orbit rings
    planets.forEach(p=>{
      ctx.beginPath(); ctx.arc(cx,cy,p.dist*scale,0,Math.PI*2);
      ctx.strokeStyle='rgba(0,245,255,0.07)'; ctx.lineWidth=1; ctx.stroke();
    });

    // Sun
    const sunGrad = ctx.createRadialGradient(cx,cy,0,cx,cy,40*scale);
    sunGrad.addColorStop(0,'#fff8e0');
    sunGrad.addColorStop(0.3,'#ffa500');
    sunGrad.addColorStop(0.7,'#ff6000');
    sunGrad.addColorStop(1,'transparent');
    ctx.beginPath(); ctx.arc(cx,cy,38*scale,0,Math.PI*2);
    ctx.fillStyle=sunGrad; ctx.fill();
    // Sun corona
    ctx.beginPath(); ctx.arc(cx,cy,50*scale,0,Math.PI*2);
    ctx.strokeStyle='rgba(255,160,0,0.15)'; ctx.lineWidth=12*scale; ctx.stroke();

    // Planets
    planets.forEach((p,i)=>{
      const px=cx+Math.cos(angles[i])*p.dist*scale;
      const py=cy+Math.sin(angles[i])*p.dist*scale;

      if(p.ring){
        ctx.save();
        ctx.translate(px,py);
        ctx.scale(1,0.35);
        ctx.beginPath();
        ctx.arc(0,0,(p.r+14)*scale,0,Math.PI*2);
        ctx.strokeStyle='rgba(221,184,106,0.5)'; ctx.lineWidth=5*scale; ctx.stroke();
        ctx.restore();
      }

      const glowR = ctx.createRadialGradient(px,py,0,px,py,p.r*scale*2);
      glowR.addColorStop(0,p.color);
      glowR.addColorStop(1,'transparent');
      ctx.beginPath(); ctx.arc(px,py,p.r*scale*2,0,Math.PI*2);
      ctx.fillStyle=p.glow; ctx.fill();

      ctx.beginPath(); ctx.arc(px,py,p.r*scale,0,Math.PI*2);
      ctx.fillStyle=p.color;
      if(hovered===i){ ctx.shadowBlur=20; ctx.shadowColor=p.glow; }
      ctx.fill(); ctx.shadowBlur=0;

      if(hovered===i){
        ctx.font=`bold ${11*scale}px "Share Tech Mono",monospace`;
        ctx.fillStyle='rgba(200,224,255,0.9)';
        ctx.textAlign='center';
        ctx.fillText(p.name,px,py-(p.r*scale+12));
      }

      angles[i] += p.speed*0.012;
    });

    requestAnimationFrame(draw);
  }
  draw();
})();

// ── LIVE LOG ticker ──
(function(){
  const msgs = [
    {t:'warn', m:'Micrometeorite proximity alert — 3.2km separation.'},
    {t:'ok',   m:'Course correction burn complete. On nominal trajectory.'},
    {t:'',     m:'Science payload collecting atmospheric particulate data.'},
    {t:'ok',   m:'Ground uplink re-established. Telemetry synced.'},
    {t:'alert',m:'Temperature spike in thruster B module. Auto-cooling active.'},
    {t:'',     m:'Crew meal period. Low-activity monitoring mode.'},
    {t:'ok',   m:'EVA hatch sealed. Pressure nominal.'},
  ];
  let idx=0, tSec=0;
  setInterval(()=>{
    tSec++;
    const log = document.getElementById('missionLog');
    if(!log) return;
    const m = msgs[idx%msgs.length];
    const h=String(Math.floor(tSec/3600)).padStart(2,'0');
    const min=String(Math.floor((tSec%3600)/60)).padStart(2,'0');
    const s=String(tSec%60).padStart(2,'0');
    const entry=document.createElement('div');
    entry.className='log-entry';
    entry.innerHTML=`<span class="log-time">T+${h}:${min}:${s}</span><span class="log-msg ${m.t}">${m.m}</span>`;
    log.insertBefore(entry,log.firstChild);
    if(log.children.length>10) log.removeChild(log.lastChild);
    idx++;
  },4000);
})();

// ── SUN CANVAS ──
(function(){
  const canvas = document.getElementById('sunCanvas');
  if(!canvas) return;
  function resize(){
    const w = canvas.parentElement.offsetWidth;
    canvas.width = w; canvas.height = w;
  }
  resize();
  window.addEventListener('resize', resize);
  const ctx = canvas.getContext('2d');
  let t = 0;

  function drawSun(){
    const w = canvas.width, h = canvas.height;
    const cx = w/2, cy = h/2;
    const R = Math.min(w,h)*0.36;
    ctx.clearRect(0,0,w,h);

    // Deep space bg
    ctx.fillStyle = '#020510';
    ctx.fillRect(0,0,w,h);

    // Outer corona glow layers
    for(let i=5;i>0;i--){
      const grad = ctx.createRadialGradient(cx,cy,R*0.9,cx,cy,R*(1+i*0.32));
      grad.addColorStop(0, `rgba(255,${100+i*20},0,${0.06-i*0.01})`);
      grad.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.beginPath(); ctx.arc(cx,cy,R*(1+i*0.32),0,Math.PI*2);
      ctx.fillStyle=grad; ctx.fill();
    }

    // Animated corona spikes
    ctx.save();
    ctx.translate(cx,cy);
    for(let i=0;i<24;i++){
      const angle = (i/24)*Math.PI*2 + t*0.003;
      const len = R*(0.18 + 0.12*Math.sin(t*0.04+i*0.7));
      const width = 0.04 + 0.02*Math.sin(t*0.06+i);
      ctx.save();
      ctx.rotate(angle);
      const spkGrad = ctx.createLinearGradient(0,0,R+len,0);
      spkGrad.addColorStop(0,'rgba(255,160,0,0.7)');
      spkGrad.addColorStop(0.5,'rgba(255,100,0,0.3)');
      spkGrad.addColorStop(1,'rgba(255,50,0,0)');
      ctx.beginPath();
      ctx.moveTo(R*0.95,0);
      ctx.lineTo(R+len, -R*width);
      ctx.lineTo(R+len*1.3, 0);
      ctx.lineTo(R+len, R*width);
      ctx.closePath();
      ctx.fillStyle=spkGrad; ctx.fill();
      ctx.restore();
    }
    ctx.restore();

    // Solar prominences (arcs)
    for(let p=0;p<3;p++){
      const baseAngle = (p/3)*Math.PI*2 + t*0.002;
      const arcR = R*(1.1 + 0.15*Math.sin(t*0.015+p));
      ctx.save();
      ctx.translate(cx,cy);
      ctx.rotate(baseAngle);
      ctx.beginPath();
      ctx.arc(R*0.8, 0, R*0.35, -Math.PI*0.4, Math.PI*0.4);
      ctx.strokeStyle = `rgba(255,${80+p*40},0,${0.4+0.2*Math.sin(t*0.02+p)})`;
      ctx.lineWidth = 3;
      ctx.stroke();
      ctx.restore();
    }

    // Sun body gradient
    const sunGrad = ctx.createRadialGradient(cx-R*0.2, cy-R*0.2, 0, cx, cy, R);
    sunGrad.addColorStop(0, '#fff8e0');
    sunGrad.addColorStop(0.2, '#ffe060');
    sunGrad.addColorStop(0.5, '#ffa000');
    sunGrad.addColorStop(0.75, '#ff6000');
    sunGrad.addColorStop(1, '#cc2800');
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2);
    ctx.fillStyle = sunGrad; ctx.fill();

    // Sunspot granulation texture
    ctx.save();
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2); ctx.clip();
    for(let g=0;g<60;g++){
      const gx = cx + (Math.sin(g*137.5+t*0.005)*R*0.8);
      const gy = cy + (Math.cos(g*137.5+t*0.004)*R*0.8);
      const gr2 = ctx.createRadialGradient(gx,gy,0,gx,gy,R*0.09);
      gr2.addColorStop(0,'rgba(255,200,50,0.18)');
      gr2.addColorStop(1,'rgba(255,100,0,0)');
      ctx.beginPath(); ctx.arc(gx,gy,R*0.09,0,Math.PI*2);
      ctx.fillStyle=gr2; ctx.fill();
    }
    // Sunspots
    const spots = [
      {ax:0.25,ay:0.18,sr:0.055},
      {ax:-0.3,ay:-0.22,sr:0.04},
      {ax:0.1,ay:-0.35,sr:0.03},
    ];
    spots.forEach(s=>{
      const sx = cx+R*(s.ax+0.04*Math.sin(t*0.008)), sy=cy+R*(s.ay+0.03*Math.cos(t*0.007));
      const sg = ctx.createRadialGradient(sx,sy,0,sx,sy,R*s.sr);
      sg.addColorStop(0,'rgba(80,20,0,0.7)');
      sg.addColorStop(0.6,'rgba(120,40,0,0.4)');
      sg.addColorStop(1,'rgba(200,80,0,0)');
      ctx.beginPath(); ctx.arc(sx,sy,R*s.sr,0,Math.PI*2);
      ctx.fillStyle=sg; ctx.fill();
    });
    ctx.restore();

    // Rim glow
    const rimGrad = ctx.createRadialGradient(cx,cy,R*0.82,cx,cy,R);
    rimGrad.addColorStop(0,'rgba(255,80,0,0)');
    rimGrad.addColorStop(1,'rgba(255,160,0,0.35)');
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2);
    ctx.fillStyle=rimGrad; ctx.fill();

    t++;
    requestAnimationFrame(drawSun);
  }
  drawSun();
})();

// ── MOON CANVAS ──
(function(){
  const canvas = document.getElementById('moonCanvas');
  if(!canvas) return;
  function resize(){
    const w = canvas.parentElement.offsetWidth;
    canvas.width = Math.min(w,420); canvas.height = Math.min(w,420);
  }
  resize();
  window.addEventListener('resize', resize);
  const ctx = canvas.getContext('2d');
  let t = 0;

  const craters = [
    {x:0.15,y:-0.1,r:0.12},{x:-0.28,y:0.22,r:0.09},{x:0.3,y:0.3,r:0.07},
    {x:-0.05,y:0.35,r:0.11},{x:0.22,y:-0.3,r:0.06},{x:-0.3,y:-0.1,r:0.08},
    {x:0.05,y:0.05,r:0.04},{x:-0.18,y:-0.32,r:0.05},{x:0.35,y:-0.05,r:0.05},
    {x:-0.1,y:0.15,r:0.035},{x:0.1,y:-0.18,r:0.03},{x:-0.32,y:0.08,r:0.06}
  ];

  function drawMoon(){
    const w=canvas.width, h=canvas.height;
    const cx=w/2, cy=h/2;
    const R=Math.min(w,h)*0.4;
    ctx.clearRect(0,0,w,h);
    ctx.fillStyle='#020510'; ctx.fillRect(0,0,w,h);

    // Moon outer glow
    const moonGlow = ctx.createRadialGradient(cx,cy,R*0.9,cx,cy,R*1.35);
    moonGlow.addColorStop(0,'rgba(180,200,240,0.12)');
    moonGlow.addColorStop(1,'rgba(0,0,0,0)');
    ctx.beginPath(); ctx.arc(cx,cy,R*1.35,0,Math.PI*2);
    ctx.fillStyle=moonGlow; ctx.fill();

    // Moon body
    const moonGrad = ctx.createRadialGradient(cx-R*0.25, cy-R*0.25, R*0.05, cx, cy, R);
    moonGrad.addColorStop(0,'#e8eaf0');
    moonGrad.addColorStop(0.3,'#c8cad8');
    moonGrad.addColorStop(0.7,'#9498b0');
    moonGrad.addColorStop(1,'#606480');
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2);
    ctx.fillStyle=moonGrad; ctx.fill();

    // Maria (dark patches)
    ctx.save();
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2); ctx.clip();
    const maria = [
      {x:-0.1,y:-0.05,rx:0.38,ry:0.28,a:0.18},
      {x:0.3,y:-0.25,rx:0.14,ry:0.10,a:0.12},
      {x:-0.25,y:0.25,rx:0.18,ry:0.13,a:0.10},
      {x:0.15,y:0.28,rx:0.12,ry:0.08,a:0.09},
    ];
    maria.forEach(m=>{
      const mx=cx+m.x*R, my=cy+m.y*R;
      const mg=ctx.createRadialGradient(mx,my,0,mx,my,R*0.4);
      mg.addColorStop(0,`rgba(50,55,75,${m.a})`);
      mg.addColorStop(1,'rgba(0,0,0,0)');
      ctx.save();
      ctx.translate(mx,my); ctx.scale(m.rx,m.ry);
      ctx.beginPath(); ctx.arc(0,0,R,0,Math.PI*2);
      ctx.fillStyle=`rgba(40,45,65,${m.a})`; ctx.fill();
      ctx.restore();
    });

    // Craters
    craters.forEach(c=>{
      const cxc=cx+c.x*R, cyc=cy+c.y*R, cr=c.r*R;
      // Crater shadow
      ctx.beginPath(); ctx.arc(cxc+cr*0.15,cyc+cr*0.15,cr,0,Math.PI*2);
      ctx.fillStyle='rgba(30,32,50,0.5)'; ctx.fill();
      // Crater floor
      const cg=ctx.createRadialGradient(cxc-cr*0.2,cyc-cr*0.2,0,cxc,cyc,cr);
      cg.addColorStop(0,'rgba(190,195,215,0.6)');
      cg.addColorStop(0.7,'rgba(100,105,130,0.4)');
      cg.addColorStop(1,'rgba(60,65,90,0.2)');
      ctx.beginPath(); ctx.arc(cxc,cyc,cr,0,Math.PI*2);
      ctx.fillStyle=cg; ctx.fill();
      // Crater rim highlight
      ctx.beginPath(); ctx.arc(cxc,cyc,cr,Math.PI,Math.PI*2);
      ctx.strokeStyle='rgba(230,235,255,0.35)'; ctx.lineWidth=cr*0.18; ctx.stroke();
    });
    ctx.restore();

    // Terminator shadow (day/night line) — slowly moving
    const termAngle = Math.sin(t*0.002)*0.4;
    const shadowX = cx + Math.sin(termAngle)*R*0.3;
    const shadowGrad = ctx.createRadialGradient(shadowX,cy,R*0.1,cx+R*0.6,cy,R*1.1);
    shadowGrad.addColorStop(0,'rgba(0,0,0,0)');
    shadowGrad.addColorStop(0.6,'rgba(0,2,8,0.25)');
    shadowGrad.addColorStop(1,'rgba(2,5,16,0.7)');
    ctx.save();
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2); ctx.clip();
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2);
    ctx.fillStyle=shadowGrad; ctx.fill();
    ctx.restore();

    // Rim
    ctx.beginPath(); ctx.arc(cx,cy,R,0,Math.PI*2);
    ctx.strokeStyle='rgba(180,190,220,0.15)'; ctx.lineWidth=1.5; ctx.stroke();

    t++;
    requestAnimationFrame(drawMoon);
  }
  drawMoon();
})();

// ── METEOR CANVAS ──
(function(){
  const canvas = document.getElementById('meteorCanvas');
  if(!canvas) return;
  canvas.width = canvas.offsetWidth || 1200;
  canvas.height = 260;
  const ctx = canvas.getContext('2d');

  const meteors = [];
  const asteroids = [];

  function spawnMeteor(){
    const speed = 4 + Math.random()*8;
    meteors.push({
      x: Math.random()*canvas.width*1.2 - canvas.width*0.1,
      y: -10 - Math.random()*40,
      vx: (Math.random()-0.5)*2 + speed*0.4,
      vy: speed,
      len: 40 + Math.random()*80,
      alpha: 1,
      width: 0.5 + Math.random()*1.5,
      color: Math.random()>0.5 ? '#00f5ff' : '#ffaa00'
    });
  }

  function spawnAsteroid(){
    asteroids.push({
      x: -30,
      y: 30 + Math.random()*(canvas.height-60),
      vx: 0.8 + Math.random()*1.4,
      vy: (Math.random()-0.5)*0.4,
      r: 4 + Math.random()*10,
      rot: 0,
      rotSpeed: (Math.random()-0.5)*0.04,
      color: `hsl(${20+Math.random()*20},${20+Math.random()*15}%,${50+Math.random()*20}%)`
    });
  }

  for(let i=0;i<3;i++) spawnMeteor();
  for(let i=0;i<4;i++) { asteroids.push({x:Math.random()*canvas.width, y:30+Math.random()*(canvas.height-60), vx:0.8+Math.random()*1.4, vy:(Math.random()-0.5)*0.4, r:4+Math.random()*10, rot:Math.random()*Math.PI*2, rotSpeed:(Math.random()-0.5)*0.04, color:`hsl(${20+Math.random()*20},${20+Math.random()*15}%,${50+Math.random()*20}%)`}); }

  let frame = 0;

  function drawMeteors(){
    canvas.width = canvas.offsetWidth || 1200;
    const w=canvas.width, h=canvas.height;
    ctx.clearRect(0,0,w,h);

    // Background
    ctx.fillStyle='rgba(6,13,31,0.6)'; ctx.fillRect(0,0,w,h);

    // Grid
    ctx.strokeStyle='rgba(0,245,255,0.04)'; ctx.lineWidth=1;
    for(let x=0;x<w;x+=60){ ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,h); ctx.stroke(); }
    for(let y=0;y<h;y+=40){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(w,y); ctx.stroke(); }

    // Asteroids
    asteroids.forEach((a,i)=>{
      a.x += a.vx; a.y += a.vy; a.rot += a.rotSpeed;
      if(a.x > w+40) { a.x=-30; a.y=30+Math.random()*(h-60); a.vx=0.8+Math.random()*1.4; a.r=4+Math.random()*10; }

      ctx.save();
      ctx.translate(a.x,a.y); ctx.rotate(a.rot);
      ctx.beginPath();
      const sides = 5 + Math.floor(Math.random()*0); // keep shape consistent per asteroid
      for(let s=0;s<6;s++){
        const angle=(s/6)*Math.PI*2;
        const dist=a.r*(0.7+0.3*Math.sin(s*2.3+a.rot*3));
        s===0 ? ctx.moveTo(Math.cos(angle)*dist,Math.sin(angle)*dist)
              : ctx.lineTo(Math.cos(angle)*dist,Math.sin(angle)*dist);
      }
      ctx.closePath();
      ctx.fillStyle=a.color; ctx.fill();
      ctx.strokeStyle='rgba(200,180,140,0.4)'; ctx.lineWidth=0.8; ctx.stroke();

      // Glow
      const ag=ctx.createRadialGradient(0,0,0,0,0,a.r*2);
      ag.addColorStop(0,'rgba(200,150,80,0.15)');
      ag.addColorStop(1,'rgba(0,0,0,0)');
      ctx.beginPath(); ctx.arc(0,0,a.r*2,0,Math.PI*2);
      ctx.fillStyle=ag; ctx.fill();
      ctx.restore();

      // Speed trail
      ctx.save();
      const trailGrad=ctx.createLinearGradient(a.x,a.y,a.x-a.vx*20,a.y-a.vy*20);
      trailGrad.addColorStop(0,'rgba(200,150,80,0.25)');
      trailGrad.addColorStop(1,'rgba(200,150,80,0)');
      ctx.strokeStyle=trailGrad; ctx.lineWidth=a.r*0.5;
      ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(a.x-a.vx*18,a.y-a.vy*18);
      ctx.stroke();
      ctx.restore();
    });

    // Meteors (shooting stars)
    meteors.forEach((m,i)=>{
      m.x += m.vx; m.y += m.vy; m.alpha -= 0.012;

      if(m.alpha<=0 || m.y>h+20){
        Object.assign(m,{
          x:Math.random()*w*1.2-w*0.1, y:-10-Math.random()*40,
          vx:(Math.random()-0.5)*2+(4+Math.random()*8)*0.4,
          vy:4+Math.random()*8, len:40+Math.random()*80,
          alpha:1, width:0.5+Math.random()*1.5,
          color:Math.random()>0.5?'#00f5ff':'#ffaa00'
        });
        return;
      }

      const angle = Math.atan2(m.vy,m.vx);
      const tx=m.x-Math.cos(angle)*m.len, ty=m.y-Math.sin(angle)*m.len;

      // Tail
      const metGrad=ctx.createLinearGradient(m.x,m.y,tx,ty);
      metGrad.addColorStop(0,m.color.replace(')',`,${m.alpha})`).replace('rgb','rgba').replace('#00f5ff',`rgba(0,245,255,${m.alpha})`).replace('#ffaa00',`rgba(255,170,0,${m.alpha})`));
      metGrad.addColorStop(1,'rgba(0,0,0,0)');
      ctx.beginPath(); ctx.moveTo(m.x,m.y); ctx.lineTo(tx,ty);
      ctx.strokeStyle=metGrad; ctx.lineWidth=m.width; ctx.stroke();

      // Head glow
      ctx.beginPath(); ctx.arc(m.x,m.y,m.width*2.5,0,Math.PI*2);
      ctx.fillStyle=m.color==='#00f5ff'?`rgba(0,245,255,${m.alpha*0.9})`:`rgba(255,170,0,${m.alpha*0.9})`;
      ctx.shadowBlur=8; ctx.shadowColor=m.color;
      ctx.fill(); ctx.shadowBlur=0;
    });

    // Spawn new meteors periodically
    if(frame%55===0) spawnMeteor();
    if(frame%180===0) spawnAsteroid();

    // Scan lines
    for(let y=0;y<h;y+=5){ ctx.fillStyle='rgba(0,0,0,0.025)'; ctx.fillRect(0,y,w,2); }

    // Labels
    ctx.font='9px "Share Tech Mono",monospace';
    ctx.fillStyle='rgba(0,245,255,0.3)';
    ctx.fillText('METEOR DETECTION ARRAY — LIVE SIMULATION', 12, 18);
    ctx.fillStyle='rgba(255,170,0,0.3)';
    ctx.fillText(`TRACKED OBJECTS: ${meteors.length + asteroids.length}`, w-200, 18);

    frame++;
    requestAnimationFrame(drawMeteors);
  }
  drawMeteors();
})();
</script>
